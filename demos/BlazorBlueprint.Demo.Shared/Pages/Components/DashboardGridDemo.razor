@code {
    // Editable state
    private BlazorBlueprint.Primitives.DashboardGrid.DashboardGridState editableState = new();

    // Toggle edit mode
    private bool isEditable = true;

    // Responsive breakpoint
    private BlazorBlueprint.Primitives.DashboardGrid.DashboardBreakpoint? currentBreakpoint;

    // State persistence
    private BlazorBlueprint.Primitives.DashboardGrid.DashboardGridState persistState = new();
    private BlazorBlueprint.Primitives.DashboardGrid.DashboardGridStateSnapshot? savedSnapshot;
    private static readonly JsonSerializerOptions jsonOptions = new() { WriteIndented = true };

    // Dynamic widgets
    private List<DynamicWidget> dynamicWidgets = new();
    private int nextWidgetId = 1;

    private void HandleBreakpointChanged(BlazorBlueprint.Primitives.DashboardGrid.DashboardBreakpoint bp) =>
        currentBreakpoint = bp;

    private void SaveState()
    {
        savedSnapshot = persistState.Save();
        StateHasChanged();
    }

    private void RestoreState()
    {
        if (savedSnapshot != null)
        {
            persistState.Restore(savedSnapshot);
            StateHasChanged();
        }
    }

    private void ResetState()
    {
        persistState.Reset();
        savedSnapshot = null;
        StateHasChanged();
    }

    private void AddWidget()
    {
        var id = nextWidgetId++;
        // Place widgets in a 3-column layout, auto-advancing rows
        var index = dynamicWidgets.Count;
        var col = (index % 3) * 4 + 1;
        var row = (index / 3) * 3 + 1;

        dynamicWidgets.Add(new DynamicWidget
        {
            Id = $"dynamic-{id}",
            Title = $"Widget {id}",
            Column = col,
            Row = row,
            ColSpan = 4,
            RowSpan = 3
        });
    }

    private void RemoveWidget(string widgetId) =>
        dynamicWidgets.RemoveAll(w => w.Id == widgetId);

    private void RemoveLastWidget()
    {
        if (dynamicWidgets.Count > 0)
        {
            dynamicWidgets.RemoveAt(dynamicWidgets.Count - 1);
        }
    }

    private class DynamicWidget
    {
        public string Id { get; set; } = string.Empty;
        public string Title { get; set; } = string.Empty;
        public int Column { get; set; } = 1;
        public int Row { get; set; } = 1;
        public int ColSpan { get; set; } = 4;
        public int RowSpan { get; set; } = 3;
    }
}
