@page "/components/dashboard-grid-data-driven"
@using System.Text.Json

<PageTitle>Data-Driven Dashboard - Blazor Blueprint</PageTitle>

<div class="space-y-6 max-w-7xl">
    <div class="space-y-4">
        <h1 class="text-4xl font-bold tracking-tight">Data-Driven Dashboard</h1>
        <p class="text-xl text-muted-foreground">
            A fully data-driven dashboard where widget layout and content are loaded from JSON
            at runtime -- simulating a backend API call. Users can rearrange, resize, and remove
            widgets, then save the layout back to JSON for persistence.
        </p>
        <p class="text-sm text-muted-foreground leading-relaxed max-w-3xl">
            This pattern separates <strong>layout</strong> (positions on the grid) from
            <strong>widget configuration</strong> (what each widget displays). Both are stored
            together in a single JSON payload and loaded on demand. The grid manages spatial
            positioning while your code maps widget types to Blazor content.
        </p>
    </div>

    <div class="flex flex-wrap gap-2">
        @if (!dashboardLoaded)
        {
            <BbButton OnClick="LoadDashboard" Variant="ButtonVariant.Default" Size="ButtonSize.Small">
                <LucideIcon Name="download" Class="h-4 w-4 mr-2" /> Load Dashboard
            </BbButton>
        }
        else
        {
            <BbButton OnClick="SaveDashboard" Variant="ButtonVariant.Outline" Size="ButtonSize.Small">
                <LucideIcon Name="save" Class="h-4 w-4 mr-2" /> Save Layout
            </BbButton>
            <BbButton OnClick="UnloadDashboard" Variant="ButtonVariant.Destructive" Size="ButtonSize.Small">
                <LucideIcon Name="x" Class="h-4 w-4 mr-2" /> Unload
            </BbButton>
        }
    </div>

    <BbDashboardGrid @ref="gridRef" Columns="12" RowHeight="80" Gap="16" @bind-State="gridState"
                     Loading="@isLoading" Background="DashboardBackground.Squares" Border="true">
        @foreach (var widget in widgets)
        {
            <BbDashboardWidget @key="widget.Id" Id="@widget.Id"
                              Column="@widget.Column" Row="@widget.Row"
                              ColumnSpan="@widget.ColSpan" RowSpan="@widget.RowSpan"
                              Title="@widget.Title" OnRemove="RemoveWidget">
                @RenderWidgetContent(widget)
            </BbDashboardWidget>
        }
    </BbDashboardGrid>

    @if (savedJson != null)
    {
        <div class="space-y-2">
            <h3 class="text-sm font-semibold">Saved JSON</h3>
            <pre class="text-xs bg-muted p-4 rounded-lg overflow-auto max-h-60">@savedJson</pre>
        </div>
    }
</div>

@code {
    private BbDashboardGrid? gridRef;
    private BlazorBlueprint.Primitives.DashboardGrid.DashboardGridState gridState = new();
    private List<WidgetConfig> widgets = new();
    private bool dashboardLoaded;
    private bool isLoading;
    private string? savedJson;

    private static readonly JsonSerializerOptions JsonOptions = new()
    {
        WriteIndented = true,
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase
    };

    // ── Load: simulate an API call that returns layout + widget config ──

    private async Task LoadDashboard()
    {
        isLoading = true;
        StateHasChanged();

        // Simulate network latency
        await Task.Delay(800);

        var payload = JsonSerializer.Deserialize<DashboardPayload>(SampleDashboardJson, JsonOptions)!;

        // 1. Build widget list from the payload
        widgets = payload.Widgets;

        // 2. Build grid state from the layout positions
        gridState = new BlazorBlueprint.Primitives.DashboardGrid.DashboardGridState();
        foreach (var w in widgets)
        {
            gridState.RegisterWidget(w.Id, w.Column, w.Row, w.ColSpan, w.RowSpan);
        }

        dashboardLoaded = true;
        isLoading = false;
        savedJson = null;
    }

    private void UnloadDashboard()
    {
        widgets.Clear();
        gridState = new BlazorBlueprint.Primitives.DashboardGrid.DashboardGridState();
        dashboardLoaded = false;
        savedJson = null;
    }

    // ── Save: GetConfig() returns the complete dashboard configuration ──

    private void SaveDashboard()
    {
        var config = gridRef?.GetConfig();
        savedJson = config != null ? JsonSerializer.Serialize(config, JsonOptions) : null;
    }

    private void RemoveWidget(string widgetId)
    {
        widgets.RemoveAll(w => w.Id == widgetId);
    }

    // ── Render: map widget type to Blazor content ──

    private RenderFragment RenderWidgetContent(WidgetConfig widget) => widget.Type switch
    {
        "bar-chart" => RenderBarChart(widget),
        "area-chart" => RenderAreaChart(widget),
        "line-chart" => RenderLineChart(widget),
        "pie-chart" => RenderPieChart(widget),
        "kpi" => RenderKpi(widget),
        "table" => RenderTable(widget),
        _ => @<div class="flex items-center justify-center h-full text-muted-foreground text-sm">Unknown widget type: @widget.Type</div>
    };

    private RenderFragment RenderBarChart(WidgetConfig widget) => __builder =>
    {
        <BbBarChart Data="@GetTimeSeriesData(widget)" Height="100%">
            <BbXAxis DataKey="month" />
            <BbYAxis Show="false" />
            <BbChartTooltip />
            <BbBar DataKey="value" Name="@widget.Title" Color="var(--chart-1)" />
        </BbBarChart>
    };

    private RenderFragment RenderAreaChart(WidgetConfig widget) => __builder =>
    {
        <BbAreaChart Data="@GetTimeSeriesData(widget)" Height="100%">
            <BbXAxis DataKey="month" />
            <BbYAxis Show="false" />
            <BbChartTooltip />
            <BbArea DataKey="value" Name="@widget.Title" Color="var(--chart-2)" Curve="CurveType.Smooth">
                <BbFill>
                    <BbLinearGradient>
                        <BbGradientStop Offset="0" Color="var(--chart-2)" Opacity="0.5" />
                        <BbGradientStop Offset="1" Color="var(--chart-2)" Opacity="0.05" />
                    </BbLinearGradient>
                </BbFill>
            </BbArea>
        </BbAreaChart>
    };

    private RenderFragment RenderLineChart(WidgetConfig widget) => __builder =>
    {
        <BbLineChart Data="@GetTimeSeriesData(widget)" Height="100%">
            <BbXAxis DataKey="month" />
            <BbYAxis Show="false" />
            <BbChartTooltip />
            <BbLine DataKey="value" Name="@widget.Title" Color="var(--chart-3)" Curve="CurveType.Smooth" />
        </BbLineChart>
    };

    private RenderFragment RenderPieChart(WidgetConfig widget) => __builder =>
    {
        <BbPieChart Data="@GetCategoryData(widget)" Height="100%">
            <BbChartTooltip />
            <BbChartLegend />
            <BbPie DataKey="value" NameKey="name" />
        </BbPieChart>
    };

    private RenderFragment RenderKpi(WidgetConfig widget) => __builder =>
    {
        var kpi = GetKpiData(widget);
        <div class="flex flex-col items-center justify-center h-full gap-1">
            <span class="text-4xl font-bold tracking-tight">@kpi.Value</span>
            <span class="text-sm text-muted-foreground">@kpi.Label</span>
            @if (kpi.Change != null)
            {
                var isPositive = kpi.Change.StartsWith("+");
                <span class="text-xs @(isPositive ? "text-green-500" : "text-red-500")">
                    @kpi.Change from last month
                </span>
            }
        </div>
    };

    private RenderFragment RenderTable(WidgetConfig widget) => __builder =>
    {
        var rows = GetTableData(widget);
        <div class="overflow-auto h-full">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b text-left text-muted-foreground">
                        <th class="py-2 px-3 font-medium">Name</th>
                        <th class="py-2 px-3 font-medium text-right">Value</th>
                        <th class="py-2 px-3 font-medium text-right">Change</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in rows)
                    {
                        <tr class="border-b last:border-0">
                            <td class="py-2 px-3">@row.Name</td>
                            <td class="py-2 px-3 text-right font-medium">@row.Value</td>
                            <td class="py-2 px-3 text-right @(row.IsPositive ? "text-green-500" : "text-red-500")">
                                @row.Change
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    };

    // ── Data resolvers: map widget DataSource to chart data ──

    private List<TimeSeriesPoint> GetTimeSeriesData(WidgetConfig widget)
    {
        return widget.DataSource switch
        {
            "revenue" => new()
            {
                new() { Month = "Jan", Value = 4200 }, new() { Month = "Feb", Value = 5100 },
                new() { Month = "Mar", Value = 4800 }, new() { Month = "Apr", Value = 6200 },
                new() { Month = "May", Value = 5900 }, new() { Month = "Jun", Value = 7100 },
            },
            "users" => new()
            {
                new() { Month = "Jan", Value = 1200 }, new() { Month = "Feb", Value = 1350 },
                new() { Month = "Mar", Value = 1500 }, new() { Month = "Apr", Value = 1420 },
                new() { Month = "May", Value = 1680 }, new() { Month = "Jun", Value = 1950 },
            },
            "orders" => new()
            {
                new() { Month = "Jan", Value = 320 }, new() { Month = "Feb", Value = 410 },
                new() { Month = "Mar", Value = 380 }, new() { Month = "Apr", Value = 450 },
                new() { Month = "May", Value = 520 }, new() { Month = "Jun", Value = 480 },
            },
            "pageviews" => new()
            {
                new() { Month = "Jan", Value = 12400 }, new() { Month = "Feb", Value = 14200 },
                new() { Month = "Mar", Value = 13800 }, new() { Month = "Apr", Value = 15600 },
                new() { Month = "May", Value = 17200 }, new() { Month = "Jun", Value = 16900 },
            },
            _ => new()
            {
                new() { Month = "Jan", Value = 100 }, new() { Month = "Feb", Value = 120 },
                new() { Month = "Mar", Value = 140 }, new() { Month = "Apr", Value = 130 },
                new() { Month = "May", Value = 150 }, new() { Month = "Jun", Value = 170 },
            }
        };
    }

    private List<CategoryPoint> GetCategoryData(WidgetConfig widget)
    {
        return widget.DataSource switch
        {
            "traffic-sources" => new()
            {
                new() { Name = "Direct", Value = 4200, Fill = "var(--chart-1)" },
                new() { Name = "Organic", Value = 3100, Fill = "var(--chart-2)" },
                new() { Name = "Referral", Value = 1800, Fill = "var(--chart-3)" },
                new() { Name = "Social", Value = 1200, Fill = "var(--chart-4)" },
                new() { Name = "Email", Value = 900, Fill = "var(--chart-5)" },
            },
            "browsers" => new()
            {
                new() { Name = "Chrome", Value = 5400, Fill = "var(--chart-1)" },
                new() { Name = "Safari", Value = 2100, Fill = "var(--chart-2)" },
                new() { Name = "Firefox", Value = 1200, Fill = "var(--chart-3)" },
                new() { Name = "Edge", Value = 800, Fill = "var(--chart-4)" },
                new() { Name = "Other", Value = 400, Fill = "var(--chart-5)" },
            },
            _ => new()
            {
                new() { Name = "A", Value = 40, Fill = "var(--chart-1)" },
                new() { Name = "B", Value = 30, Fill = "var(--chart-2)" },
                new() { Name = "C", Value = 20, Fill = "var(--chart-3)" },
                new() { Name = "D", Value = 10, Fill = "var(--chart-4)" },
            }
        };
    }

    private KpiData GetKpiData(WidgetConfig widget)
    {
        return widget.DataSource switch
        {
            "total-revenue" => new() { Value = "$48,250", Label = "Total Revenue", Change = "+12.5%" },
            "active-users" => new() { Value = "2,420", Label = "Active Users", Change = "+8.1%" },
            "conversion-rate" => new() { Value = "3.2%", Label = "Conversion Rate", Change = "+0.4%" },
            "total-orders" => new() { Value = "1,210", Label = "Total Orders", Change = "-2.1%" },
            _ => new() { Value = "—", Label = widget.Title }
        };
    }

    private List<TableRow> GetTableData(WidgetConfig widget)
    {
        return widget.DataSource switch
        {
            "top-products" => new()
            {
                new() { Name = "Widget Pro", Value = "$12,400", Change = "+14%", IsPositive = true },
                new() { Name = "Dashboard Kit", Value = "$8,200", Change = "+8%", IsPositive = true },
                new() { Name = "Analytics Tool", Value = "$6,100", Change = "-3%", IsPositive = false },
                new() { Name = "Chart Library", Value = "$4,800", Change = "+22%", IsPositive = true },
                new() { Name = "Form Builder", Value = "$3,600", Change = "+5%", IsPositive = true },
            },
            _ => new()
            {
                new() { Name = "Item A", Value = "100", Change = "+10%", IsPositive = true },
                new() { Name = "Item B", Value = "80", Change = "-5%", IsPositive = false },
            }
        };
    }

    // ── Models ──

    public class DashboardPayload
    {
        public List<WidgetConfig> Widgets { get; set; } = new();
    }

    public class WidgetConfig
    {
        public string Id { get; set; } = string.Empty;
        public string Title { get; set; } = string.Empty;
        public string Type { get; set; } = string.Empty;
        public string DataSource { get; set; } = string.Empty;
        public int Column { get; set; } = 1;
        public int Row { get; set; } = 1;
        public int ColSpan { get; set; } = 4;
        public int RowSpan { get; set; } = 3;
    }

    public class TimeSeriesPoint
    {
        public string Month { get; set; } = "";
        public int Value { get; set; }
    }

    public class CategoryPoint
    {
        public string Name { get; set; } = "";
        public int Value { get; set; }
        public string Fill { get; set; } = "";
    }

    public class KpiData
    {
        public string Value { get; set; } = "";
        public string Label { get; set; } = "";
        public string? Change { get; set; }
    }

    public class TableRow
    {
        public string Name { get; set; } = "";
        public string Value { get; set; } = "";
        public string Change { get; set; } = "";
        public bool IsPositive { get; set; }
    }

    // ── Sample JSON payload ──
    // In a real app this would come from an API endpoint.
    // It contains both layout positions and widget configuration.

    private const string SampleDashboardJson = @"{
  ""widgets"": [
    { ""id"": ""kpi-revenue"", ""title"": ""Total Revenue"", ""type"": ""kpi"", ""dataSource"": ""total-revenue"", ""column"": 1, ""row"": 1, ""colSpan"": 3, ""rowSpan"": 2 },
    { ""id"": ""kpi-users"", ""title"": ""Active Users"", ""type"": ""kpi"", ""dataSource"": ""active-users"", ""column"": 4, ""row"": 1, ""colSpan"": 3, ""rowSpan"": 2 },
    { ""id"": ""kpi-conversion"", ""title"": ""Conversion Rate"", ""type"": ""kpi"", ""dataSource"": ""conversion-rate"", ""column"": 7, ""row"": 1, ""colSpan"": 3, ""rowSpan"": 2 },
    { ""id"": ""kpi-orders"", ""title"": ""Total Orders"", ""type"": ""kpi"", ""dataSource"": ""total-orders"", ""column"": 10, ""row"": 1, ""colSpan"": 3, ""rowSpan"": 2 },
    { ""id"": ""chart-revenue"", ""title"": ""Revenue Trend"", ""type"": ""area-chart"", ""dataSource"": ""revenue"", ""column"": 1, ""row"": 3, ""colSpan"": 8, ""rowSpan"": 4 },
    { ""id"": ""chart-traffic"", ""title"": ""Traffic Sources"", ""type"": ""pie-chart"", ""dataSource"": ""traffic-sources"", ""column"": 9, ""row"": 3, ""colSpan"": 4, ""rowSpan"": 4 },
    { ""id"": ""chart-users"", ""title"": ""User Growth"", ""type"": ""bar-chart"", ""dataSource"": ""users"", ""column"": 1, ""row"": 7, ""colSpan"": 4, ""rowSpan"": 4 },
    { ""id"": ""chart-orders"", ""title"": ""Order Volume"", ""type"": ""line-chart"", ""dataSource"": ""orders"", ""column"": 5, ""row"": 7, ""colSpan"": 4, ""rowSpan"": 4 },
    { ""id"": ""table-products"", ""title"": ""Top Products"", ""type"": ""table"", ""dataSource"": ""top-products"", ""column"": 9, ""row"": 7, ""colSpan"": 4, ""rowSpan"": 4 }
  ]
}";
}
