@* A DataGrid column wrapped in a reusable component. Because the column is produced by this
   component rather than written inline, it registers with the grid after the columns declared
   around it, so the consumer pins its position with Order. *@
<BbDataGridPropertyColumn TData="Person" TProp="int" Property="@(p => p.Salary)"
                          Format="C0" Sortable Order="@Order" />

@code {
    /// <summary>
    /// Zero-based position for the wrapped column among the grid's data columns.
    /// </summary>
    [Parameter]
    public int? Order { get; set; }
}
