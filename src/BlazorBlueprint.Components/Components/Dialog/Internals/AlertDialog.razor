@using BlazorBlueprint.Components.Components.Dialog.Internals.Shared
@inject DialogService DialogService


<DialogHeader Title="@Dialog.Title"
              Description="@Dialog.Description" />

<div class="flex justify-end">
    <BbButton OnClick="Acknowledge">
        @Dialog.Options.ButtonText
    </BbButton>
</div>

@code {
    [Parameter, EditorRequired]
    public AlertDialogData Dialog { get; set; } = default!;

    private void Acknowledge()
        => DialogService.Resolve(Dialog.Id, DialogResult.Ok());
}
