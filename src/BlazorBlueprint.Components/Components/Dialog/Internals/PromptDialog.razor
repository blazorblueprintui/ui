@using BlazorBlueprint.Components.Components.Dialog.Internals.Shared
@inject DialogService DialogService


<DialogHeader Title="@Dialog.Title"
              Description="@Dialog.Description" />

<BbInput @bind-Value="Value"
         Class="w-full"
         Placeholder="@Dialog.Options.Placeholder" />

<div class="flex flex-col-reverse sm:flex-row sm:justify-end sm:space-x-2">
    <BbButton Variant="ButtonVariant.Outline"
              OnClick="Cancel">
        @Dialog.Options.CancelText
    </BbButton>

    <BbButton Disabled="@IsDisabled"
              OnClick="Submit">
        @Dialog.Options.ConfirmText
    </BbButton>
</div>

@code {
    [Parameter, EditorRequired]
    public PromptDialogData Dialog { get; set; } = default!;

    private string? Value { get; set; }

    protected override void OnInitialized()
        => Value = Dialog.Options.DefaultValue;

    private bool IsDisabled =>
        Dialog.Options.Required && string.IsNullOrWhiteSpace(Value);

    private void Cancel()
        => DialogService.Resolve(Dialog.Id, DialogResult.Cancel());

    private void Submit()
        => DialogService.Resolve(Dialog.Id, DialogResult.Ok(Value));
}
