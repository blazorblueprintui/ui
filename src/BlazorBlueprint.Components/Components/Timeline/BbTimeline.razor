@namespace BlazorBlueprint.Components
@inject BbLocalizationOptions Localization

<ol aria-label="@Localization.Timeline.Timeline" class="@CssClass" @attributes="AdditionalAttributes">
    <CascadingValue Value="this" IsFixed="true">
        @if (ChildContent != null)
        {
            @ChildContent
        }
        else
        {
            <BbTimelineEmpty />
        }
    </CascadingValue>
</ol>
