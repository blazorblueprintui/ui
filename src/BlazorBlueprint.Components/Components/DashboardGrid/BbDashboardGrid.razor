@namespace BlazorBlueprint.Components
@using BlazorBlueprint.Primitives.DashboardGrid
@using Microsoft.JSInterop
@inject IJSRuntime JS
@implements IAsyncDisposable

<BlazorBlueprint.Primitives.DashboardGrid.BbDashboardGrid
    Context="@_context"
    AriaLabel="@AriaLabel"
    class="@CssClass"
    style="@GridStyle"
    data-dashboard-id="@_instanceId"
    data-show-grid-guide="@(ShowGridGuide ? "true" : "false")"
    data-editable="@(Editable ? "true" : "false")"
    data-positioned="@(_positioned ? "true" : "false")"
    @attributes="AdditionalAttributes">

    @if (Background != DashboardBackground.None)
    {
        <div class="@GuideOverlayClass" style="@GuideOverlayStyle" aria-hidden="true">
            @for (var i = 0; i < GuideRows * ActiveColumns; i++)
            {
                <div class="@GuideCellClass"></div>
            }
        </div>
    }

    @ChildContent
</BlazorBlueprint.Primitives.DashboardGrid.BbDashboardGrid>

<div aria-live="polite" class="sr-only" id="@(_instanceId)-live"></div>

@code {
    private DashboardGridContext _context = new();
    private IJSObjectReference? _jsModule;
    private DotNetObjectReference<BbDashboardGrid>? _dotNetRef;
    private string _instanceId = Guid.NewGuid().ToString("N");
    private bool _jsInitialized;
    private bool _disposed;
    private bool _positioned;
    private int _lastStateVersion = -1;
    private DashboardBreakpoint _lastBreakpoint = DashboardBreakpoint.Large;

    [Parameter] public int Columns { get; set; } = 12;
    [Parameter] public int RowHeight { get; set; } = 80;
    [Parameter] public int Gap { get; set; } = 16;
    [Parameter] public int MaxRows { get; set; }
    [Parameter] public DashboardGridState? State { get; set; }
    [Parameter] public EventCallback<DashboardGridState> StateChanged { get; set; }
    [Parameter] public bool AllowDrag { get; set; } = true;
    [Parameter] public bool AllowResize { get; set; } = true;
    [Parameter] public bool Editable { get; set; } = true;
    [Parameter] public bool Compact { get; set; } = true;
    [Parameter] public bool ShowGridGuide { get; set; } = true;
    [Parameter] public int MediumColumns { get; set; } = 6;
    [Parameter] public int SmallColumns { get; set; } = 1;
    [Parameter] public int MediumBreakpoint { get; set; } = 1024;
    [Parameter] public int SmallBreakpoint { get; set; } = 768;
    [Parameter] public EventCallback<WidgetDragEventArgs> OnWidgetDragEnd { get; set; }
    [Parameter] public EventCallback<WidgetResizeEventArgs> OnWidgetResizeEnd { get; set; }
    [Parameter] public EventCallback<DashboardGridLayout> OnLayoutChanged { get; set; }
    [Parameter] public EventCallback<DashboardBreakpoint> OnBreakpointChanged { get; set; }
    [Parameter] public bool Border { get; set; }
    [Parameter] public DashboardBackground Background { get; set; } = DashboardBackground.None;
    [Parameter] public string? AriaLabel { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private int ActiveColumns => _context.State.ActiveBreakpoint switch
    {
        DashboardBreakpoint.Small => SmallColumns,
        DashboardBreakpoint.Medium => MediumColumns,
        _ => Columns
    };

    private int GuideRows
    {
        get
        {
            if (MaxRows > 0)
            {
                return MaxRows;
            }

            var layout = _context.State.GetActiveLayout();
            var maxRow = 0;
            foreach (var pos in layout.Positions)
            {
                var end = pos.Row + pos.RowSpan;
                if (end > maxRow)
                {
                    maxRow = end;
                }
            }

            return Math.Max(maxRow, 4);
        }
    }

    private string CssClass => ClassNames.cn(
        "relative grid",
        Border ? "rounded-lg border p-4" : "",
        Class
    );

    private string GuideCellClass => Background switch
    {
        DashboardBackground.Lines => "bb-guide-cell-lines",
        DashboardBackground.Dots => "bb-guide-cell-dots",
        _ => ""
    };

    private string GridStyle =>
        $"grid-template-columns: repeat({ActiveColumns}, 1fr); grid-auto-rows: {RowHeight}px; gap: {Gap}px;"
        + $" --bb-dashboard-columns: {ActiveColumns}; --bb-dashboard-row-height: {RowHeight}px; --bb-dashboard-gap: {Gap}px;"
        + (MaxRows > 0 ? $" grid-template-rows: repeat({MaxRows}, {RowHeight}px);" : "");

    private string GuideOverlayClass => ClassNames.cn(
        "absolute inset-0 pointer-events-none overflow-hidden",
        Border ? "p-4" : ""
    );

    private string GuideOverlayStyle =>
        $"display: grid; grid-template-columns: repeat({ActiveColumns}, 1fr); grid-auto-rows: {RowHeight}px; gap: {Gap}px;";

    protected override void OnInitialized()
    {
        if (State != null)
        {
            _context = new DashboardGridContext(State);
            _lastStateVersion = State.Version;
        }

        SyncContextParameters();
        _context.OnStateChanged += HandleContextStateChanged;
    }

    protected override void OnParametersSet()
    {
        if (State != null && State.Version != _lastStateVersion)
        {
            _context.OnStateChanged -= HandleContextStateChanged;
            _context = new DashboardGridContext(State);
            _context.OnStateChanged += HandleContextStateChanged;
            _lastStateVersion = State.Version;
        }

        SyncContextParameters();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await InitializeJsAsync();
        }
    }

    private void SyncContextParameters()
    {
        _context.Columns = Columns;
        _context.RowHeight = RowHeight;
        _context.Gap = Gap;
        _context.AllowDrag = AllowDrag;
        _context.AllowResize = AllowResize;
        _context.Editable = Editable;
        _context.Compact = Compact;
    }

    private void HandleContextStateChanged()
    {
        InvokeAsync(async () =>
        {
            if (StateChanged.HasDelegate && State != null)
            {
                await StateChanged.InvokeAsync(State);
            }
            StateHasChanged();
        });
    }

    private async Task InitializeJsAsync()
    {
        if (_jsInitialized)
        {
            return;
        }

        try
        {
            _jsModule = await JS.InvokeAsync<IJSObjectReference>("import",
                "./_content/BlazorBlueprint.Components/js/dashboard-grid.js");
            _dotNetRef = DotNetObjectReference.Create(this);

            await _jsModule.InvokeVoidAsync("initializeDashboardGrid", _dotNetRef, _instanceId, new
            {
                columns = Columns,
                rowHeight = RowHeight,
                gap = Gap,
                allowDrag = AllowDrag && Editable,
                allowResize = AllowResize && Editable,
                editable = Editable,
                compact = Compact,
                showGridGuide = ShowGridGuide,
                mediumBreakpoint = MediumBreakpoint,
                smallBreakpoint = SmallBreakpoint,
                mediumColumns = MediumColumns,
                smallColumns = SmallColumns
            });
            _jsInitialized = true;
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException or ObjectDisposedException)
        {
        }
        catch (InvalidOperationException)
        {
        }
    }

    [JSInvokable]
    public async Task JsOnWidgetDragEnd(string widgetId, int column, int row)
    {
        if (_disposed)
        {
            return;
        }

        var current = _context.GetWidgetPosition(widgetId);
        var oldPos = current != null ? current with { } : new WidgetPosition(widgetId, 1, 1, 1, 1);
        var newPos = oldPos with { Column = column, Row = row };

        _context.UpdateWidgetPositionSilent(widgetId, column, row, oldPos.ColumnSpan, oldPos.RowSpan);
        _context.Notify();

        if (OnWidgetDragEnd.HasDelegate)
        {
            await OnWidgetDragEnd.InvokeAsync(new WidgetDragEventArgs
            {
                WidgetId = widgetId,
                OldPosition = oldPos,
                NewPosition = newPos
            });
        }
        if (OnLayoutChanged.HasDelegate)
        {
            await OnLayoutChanged.InvokeAsync(_context.State.GetActiveLayout());
        }
    }

    [JSInvokable]
    public async Task JsOnWidgetResizeEnd(string widgetId, int column, int row, int columnSpan, int rowSpan)
    {
        if (_disposed)
        {
            return;
        }

        var current = _context.GetWidgetPosition(widgetId);
        var oldPos = current != null ? current with { } : new WidgetPosition(widgetId, 1, 1, 1, 1);
        var newPos = oldPos with { Column = column, Row = row, ColumnSpan = columnSpan, RowSpan = rowSpan };

        _context.UpdateWidgetPositionSilent(widgetId, column, row, columnSpan, rowSpan);
        _context.Notify();

        if (OnWidgetResizeEnd.HasDelegate)
        {
            await OnWidgetResizeEnd.InvokeAsync(new WidgetResizeEventArgs
            {
                WidgetId = widgetId,
                OldPosition = oldPos,
                NewPosition = newPos
            });
        }
        if (OnLayoutChanged.HasDelegate)
        {
            await OnLayoutChanged.InvokeAsync(_context.State.GetActiveLayout());
        }
    }

    [JSInvokable]
    public async Task JsOnBreakpointChanged(string breakpoint)
    {
        if (_disposed)
        {
            return;
        }

        var bp = breakpoint switch
        {
            "small" => DashboardBreakpoint.Small,
            "medium" => DashboardBreakpoint.Medium,
            _ => DashboardBreakpoint.Large
        };

        if (bp != _lastBreakpoint)
        {
            _lastBreakpoint = bp;
            _context.SetActiveBreakpoint(bp);
            if (OnBreakpointChanged.HasDelegate)
            {
                await OnBreakpointChanged.InvokeAsync(bp);
            }
            StateHasChanged();
        }
    }

    [JSInvokable]
    public async Task JsOnLayoutResolved(string draggedWidgetId, LayoutChangeDto[] changes)
    {
        if (_disposed)
        {
            return;
        }

        WidgetDragEventArgs? dragArgs = null;

        foreach (var change in changes)
        {
            var existing = _context.GetWidgetPosition(change.Id);
            if (existing == null)
            {
                continue;
            }

            var oldPos = existing with { };
            _context.UpdateWidgetPositionSilent(change.Id, change.Col, change.Row, oldPos.ColumnSpan, oldPos.RowSpan);

            if (change.Id == draggedWidgetId && OnWidgetDragEnd.HasDelegate)
            {
                var newPos = oldPos with { Column = change.Col, Row = change.Row };
                dragArgs = new WidgetDragEventArgs
                {
                    WidgetId = draggedWidgetId,
                    OldPosition = oldPos,
                    NewPosition = newPos
                };
            }
        }

        _context.Notify();

        if (dragArgs != null)
        {
            await OnWidgetDragEnd.InvokeAsync(dragArgs);
        }
        if (OnLayoutChanged.HasDelegate)
        {
            await OnLayoutChanged.InvokeAsync(_context.State.GetActiveLayout());
        }
    }

    [JSInvokable]
    public async Task JsOnCompactComplete(PositionDto[] positions)
    {
        if (_disposed)
        {
            return;
        }

        foreach (var pos in positions)
        {
            _context.UpdateWidgetPositionSilent(pos.WidgetId, pos.Col, pos.Row, pos.ColSpan, pos.RowSpan);
        }

        _positioned = true;
        _context.Notify();

        if (OnLayoutChanged.HasDelegate)
        {
            await OnLayoutChanged.InvokeAsync(_context.State.GetActiveLayout());
        }
    }

    public sealed class LayoutChangeDto
    {
        public string Id { get; set; } = string.Empty;
        public int Col { get; set; }
        public int Row { get; set; }
    }

    public sealed class PositionDto
    {
        public string WidgetId { get; set; } = string.Empty;
        public int Col { get; set; }
        public int Row { get; set; }
        public int ColSpan { get; set; }
        public int RowSpan { get; set; }
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        _context.OnStateChanged -= HandleContextStateChanged;

        if (_jsModule != null && _jsInitialized)
        {
            try
            {
                await _jsModule.InvokeVoidAsync("disposeDashboardGrid", _instanceId);
            }
            catch
            {
            }

            try
            {
                await _jsModule.DisposeAsync();
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException or ObjectDisposedException)
            {
            }
        }
        _dotNetRef?.Dispose();
    }
}
